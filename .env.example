# Salesforce Import (JWT Bearer Flow / Connected App)
# SF_DOMAIN: use "login" for production, "test" for sandbox
SF_USERNAME=email
SF_CLIENT_ID=your_consumer_key_from_connected_app
SF_DOMAIN=login

# Private key: provide EITHER a file path OR the raw key string (not both)
SF_PRIVATE_KEY_FILE=/absolute/path/to/private_key.pem
# SF_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...

# Google Sheets Export
# GOOGLE_SERVICE_ACCOUNT_FILE: path to your service account JSON key file
# GOOGLE_SPREADSHEET_ID: the ID from the sheet URL:
#   https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# Share the sheet with the service account email (Editor access) before exporting
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
